import pygame as pg
from sys import exit


pg.init()
screen = pg.display.set_mode((640,360))
clock = pg.time.Clock()

while True:
    for event in pg.event.get():
        if event.type == pg.QUIT or (
            event.type == pg.KEYDOWN and event.key == pg.K_LALT
        ):
            pg.quit()
            exit()


    #game code


    pg.display.update()
    clock.tick(60)

